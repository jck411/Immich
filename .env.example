# Immich Environment Variables
# Copy to .env and fill in values:  cp .env.example .env
#
# Docs: https://docs.immich.app/install/environment-variables

# Upload location — mapped to IronWolf 8TB via LXC bind mount
UPLOAD_LOCATION=/ironwolf/Immich/upload

# Database location — stays on NVMe rootfs for fast I/O
DB_DATA_LOCATION=/opt/immich/postgres

# Timezone
TZ=America/Denver

# Immich version — pin to v2 major, or set specific like "v2.1.0"
IMMICH_VERSION=v2

# PostgreSQL credentials — change DB_PASSWORD to a random string
# Use only A-Za-z0-9, no special characters or spaces
DB_PASSWORD=CHANGE_ME_GENERATE_RANDOM_PASSWORD
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
